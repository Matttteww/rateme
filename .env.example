# Логин канала без #
TWITCH_CHANNEL=your_channel_login

# Приложение Twitch: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# OAuth токен аккаунта, который сидит в чате (можно свой стримерский).
# Нужные scope: chat:read moderator:read:chatters
# Логин ДОЛЖЕН совпадать с владельцем токена (ниже).
TWITCH_USER_ACCESS_TOKEN=

# Client-ID приложения, которым выдан TWITCH_USER_ACCESS_TOKEN (обязательно, если токен с TwitchTokenGenerator
# без своих Client ID в форме — тогда Client ID снизу на странице TTG, часто gp762nuuoqcoxypju8c569th9wz7q5).
# Если токен получен через своё приложение в dev.twitch.tv — оставь пустым или равным TWITCH_CLIENT_ID.
TWITCH_USER_TOKEN_CLIENT_ID=

# Логин владельца токена (латиницей, как в URL канала)
TWITCH_TOKEN_OWNER_LOGIN=

# Порт бэкенда (опционально)
PORT=3847

# --- Платформа / аккаунты ---
# Логин стримера: при регистрации с таким username выдаётся is_streamer
STREAMER_USERNAME=
# Синхронизация с Telegram-ботом (заголовок X-Bottwich-Sync-Secret). Должен совпадать с BottwichSyncSecret в appsettings.json бота.
BOTTWICH_SYNC_SECRET=
# Тот же секрет: бот шлёт POST /api/sync/wall-post (пост канала в ленту) и /api/tracks/from-telegram

# Токен того же бота (BotFather), что крутит ChannelFileBot. Нужен сайту для прокси /api/tracks/:id/audio (плеер без утечки токена в браузер).
TELEGRAM_BOT_TOKEN=
# Username бота без @ (если пусто — подтянется через getMe при старте сервера)
TELEGRAM_BOT_USERNAME=
# Домен для виджета входа (@BotFather /setdomain). Локально: 127.0.0.1
# TELEGRAM_PUBLIC_DOMAIN=127.0.0.1

# --- DonationAlerts (опционально, платная очередь) ---
DONATIONALERTS_CLIENT_ID=
DONATIONALERTS_CLIENT_SECRET=
DONATIONALERTS_REDIRECT_URI=http://127.0.0.1:3847/
DONATIONALERTS_ACCESS_TOKEN=
# DONATIONALERTS_POLL_MS=25000
